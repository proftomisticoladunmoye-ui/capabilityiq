# Capability IQ — environment configuration
# The platform runs fully without any keys (deterministic AI coach).
# Add a key to connect the AI Capability Coach to a live LLM.

PORT=3000

# Preferred: Anthropic (Claude)
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-opus-4-8

# Alternative: OpenAI
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o

# Alternative: OpenRouter (OpenAI-compatible gateway to many frontier models)
# OPENROUTER_API_KEY=sk-or-v1-...
# OPENROUTER_MODEL=anthropic/claude-opus-4.8   # e.g. openai/gpt-4o, openrouter/free
# OPENROUTER_SITE_URL=http://localhost:3000

# Provider precedence: Anthropic → OpenAI → OpenRouter → deterministic engine.
# Copy this file to .env (gitignored) and fill in real values.

# ---- OAuth single sign-on (optional) ----
# Supply provider credentials + redirect URI to activate the SSO buttons.
# Until set, /api/auth/oauth/:provider returns 501 and email+password auth is used.
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# MICROSOFT_CLIENT_ID=
# MICROSOFT_CLIENT_SECRET=
# APPLE_CLIENT_ID=
# APPLE_CLIENT_SECRET=
# OAUTH_REDIRECT_URI=http://localhost:3000/api/auth/oauth/callback
